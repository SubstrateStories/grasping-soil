---
import PageWrapper from '../components/PageWrapper.astro';
import HamburgerMenu from '../components/HamburgerMenu.svelte';
import { withBase } from '../lib/base';

interface Props {
	title: string;
	specialLayout: boolean;
	suppressFooter: boolean;
}

const {
	title,
	specialLayout,
	suppressFooter,
} = Astro.props;

const fontsBase = withBase('/fonts');
const fontFaces = `
@font-face { font-family: 'SeravekWeb'; src: url('${fontsBase}/SeravekWebExtraLight/SeravekWebExtraLight.woff2') format('woff2'), url('${fontsBase}/SeravekWebExtraLight/SeravekWebExtraLight.woff') format('woff'); font-weight: 200; font-style: normal; }
@font-face { font-family: 'SeravekWeb'; src: url('${fontsBase}/SeravekWebExtraLightItalic/SeravekWebExtraLightItalic.woff2') format('woff2'), url('${fontsBase}/SeravekWebExtraLightItalic/SeravekWebExtraLightItalic.woff') format('woff'); font-weight: 200; font-style: italic; }
@font-face { font-family: 'SeravekWeb'; src: url('${fontsBase}/SeravekWebLight/SeravekWebLight.woff2') format('woff2'), url('${fontsBase}/SeravekWebLight/SeravekWebLight.woff') format('woff'); font-weight: 300; font-style: normal; }
@font-face { font-family: 'SeravekWeb'; src: url('${fontsBase}/SeravekWebLightItalic/SeravekWebLightItalic.woff2') format('woff2'), url('${fontsBase}/SeravekWebLightItalic/SeravekWebLightItalic.woff') format('woff'); font-weight: 300; font-style: italic; }
@font-face { font-family: 'SeravekWeb'; src: url('${fontsBase}/SeravekWebRegular/SeravekWebRegular.woff2') format('woff2'), url('${fontsBase}/SeravekWebRegular/SeravekWebRegular.woff') format('woff'); font-weight: 400; font-style: normal; }
@font-face { font-family: 'SeravekWeb'; src: url('${fontsBase}/SeravekWebRegularItalic/SeravekWebRegularItalic.woff2') format('woff2'), url('${fontsBase}/SeravekWebRegularItalic/SeravekWebRegularItalic.woff') format('woff'); font-weight: 400; font-style: italic; }
@font-face { font-family: 'SeravekWeb'; src: url('${fontsBase}/SeravekWebMedium/SeravekWebMedium.woff2') format('woff2'), url('${fontsBase}/SeravekWebMedium/SeravekWebMedium.woff') format('woff'); font-weight: 600; font-style: normal; }
@font-face { font-family: 'SeravekWeb'; src: url('${fontsBase}/SeravekWebMediumItalic/SeravekWebMediumItalic.woff2') format('woff2'), url('${fontsBase}/SeravekWebMediumItalic/SeravekWebMediumItalic.woff') format('woff'); font-weight: 600; font-style: italic; }
@font-face { font-family: 'SeravekWeb'; src: url('${fontsBase}/SeravekWebBold/SeravekWebBold.woff2') format('woff2'), url('${fontsBase}/SeravekWebBold/SeravekWebBold.woff') format('woff'); font-weight: 700; font-style: normal; }
@font-face { font-family: 'SeravekWeb'; src: url('${fontsBase}/SeravekWebBoldItalic/SeravekWebBoldItalic.woff2') format('woff2'), url('${fontsBase}/SeravekWebBoldItalic/SeravekWebBoldItalic.woff') format('woff'); font-weight: 700; font-style: italic; }
@font-face { font-family: 'Paix'; src: url('${fontsBase}/paix-webfont.woff2') format('woff2'), url('${fontsBase}/paix-webfont.woff') format('woff'); font-weight: 700; font-style: normal; }
@font-face { font-family: 'Ocotillo'; src: url('${fontsBase}/ocotilloshadow-webfont.woff2') format('woff2'), url('${fontsBase}/ocotilloshadow-webfont.woff') format('woff'); font-weight: 100; font-style: normal; }
`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={withBase('/favicon-96x96.png')} sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<link rel="shortcut icon" href={withBase('/favicon.ico')} />
		<link rel="apple-touch-icon" sizes="180x180" href={withBase('/apple-touch-icon.png')} />
		<link rel="manifest" href={withBase('/site.webmanifest')} />
		<style is:inline set:html={fontFaces}></style>
		<meta name="generator" content={Astro.generator} />
		{title ? (
			<title>{title} | Grasping Soil</title>
		) : (
			<title>Grasping Soil</title>
		)}
	</head>
	<body class={specialLayout ? '' : 'normal-background'}>
		{!specialLayout && <HamburgerMenu client:only="svelte" />}
		{specialLayout ? (
			<slot />
		) : (
			<PageWrapper>
				<slot />
				{!suppressFooter && (
					<footer>
						<div class="content">
							<div class="left-side">
								<div>
									<ul class="primary">
										<li>
											<a href={withBase('/syllabus')}>Syllabus</a>
											<ul>
												<li><a href={withBase('/units/1-soil-as-substrate')}>1. Soil as Substrate</a></li>
												<li><a href={withBase('/units/2-soil-as-archive')}>2. Soil as Archive</a></li>
												<li><a href={withBase('/units/3-soil-as-health')}>3. Soil as Health</a></li>
												<li><a href={withBase('/units/4-soil-as-belonging')}>4. Soil as Belonging</a></li>
											</ul>
										</li>
									</ul>
								</div>
								<div>
									<ul class="primary">
										<li>
											<a href={withBase('/essays')}>Essays</a>
										</li>
										<li>
											<a href={withBase('/contributors')}>Contributors</a>
										</li>
									</ul>
								</div>
							</div>
							<div class="right-side">
								<div>&copy; {(new Date()).getFullYear()} / <a href={withBase('/colophon')}>Colophon</a></div>
							</div>
						</div>
					</footer>
				)}
			</PageWrapper>
		)}
	</body>
</html>
<style is:global>
:root {
	--max-content-width: 1280px;
	--max-page-width: 960px;
	--primary-text-color: #2d3734;
	--secondary-text-color: #565d5d;
	--tertiary-text-color: #7d8683;
	--background-color: #ffffff;
	--background-color-rgb: 255, 255, 255;
	--background-light-color: #fcfdfc;
	--background-medium-color: #f5f7f6;
	--decorative-warm-gray: #cbcfcd;
}

html {
	box-sizing: border-box;
}
*, *:before, *:after {
	box-sizing: inherit;
}

html {
	font-family: 'SeravekWeb', Seravek, 'Gill Sans Nova', Ubuntu, Calibri, 'DejaVu Sans', source-sans-pro, sans-serif;
	font-weight: normal;
}

body {
	background-color: var(--background-color);
	color: var(--secondary-text-color);
	margin: 0;
	padding: 0;
}

body.normal-background {
	background-color: var(--background-color);
}

main {
	display: flex;
	flex-direction: column;
	justify-content: flex-start;
	min-height: 100vh;
}

footer {
	min-height: 100px;
}

footer .content {
	border-color: var(--decorative-warm-gray);
	border-style: solid;
	border-width: 3px 0 0 0;
	display: grid;
	grid-template-columns: 3fr 2fr;
	margin: 0 auto;
	max-width: var(--max-content-width);
	padding: 2rem 0 3rem 0;
	width: 90%;
}

@media all and (max-width: 840px) {
	footer .content {
		grid-template-columns: 100%;
		row-gap: 2rem;
	}
}


footer .left-side {
	column-gap: 4rem;
	display: flex;
	justify-content: flex-start;
}

@media all and (max-width: 512px) {
	footer .left-side {
		flex-direction: column;
		row-gap: 2rem;
	}
}

footer .content ul {
	font-size: 1.4rem;
	font-weight: 400;
	list-style-type: none;
	margin: 0;
	padding: 0;
}

footer .content  ul.primary > li {
	font-family: 'Paix', sans-serif;
	margin-bottom: .25em;
	text-transform: uppercase;
}

footer .content li > ul {
	font-size: 1.2rem;
	font-weight: 300;
	margin-top: .5em;
	padding-left: .5em;
}

footer .content li > ul li {
	font-family: 'SeravekWeb', Seravek, 'Gill Sans Nova', Ubuntu, Calibri, 'DejaVu Sans', source-sans-pro, sans-serif;
	margin-top: .25em;
	text-transform: none;
}

footer .content a {
	color: var(--primary-text-color);
	text-decoration-color: transparent;
	transition: all ease 0.3s;
}

footer .content a:hover {
	text-decoration-color: var(--primary-text-color);
}

footer .right-side {
	display: flex;
	flex-direction: column;
	justify-content: flex-end;
	text-align: right;
}

@media all and (max-width: 512px) {
	footer .right-side {
		text-align: left;
	}
}
</style>
